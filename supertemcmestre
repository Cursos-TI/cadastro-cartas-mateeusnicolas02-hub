#include <stdio.h>

int main() {

    
    // CARTAS PRÉ-CADASTRADAS
    

    char pais1[] = "Brasil";
    int populacao1 = 203000000;
    float area1 = 8515767.0;
    float pib1 = 1868.0;
    int pontos1 = 100;
    float densidade1 = populacao1 / area1;

    char pais2[] = "Argentina";
    int populacao2 = 46000000;
    float area2 = 2780400.0;
    float pib2 = 632.0;
    int pontos2 = 60;
    float densidade2 = populacao2 / area2;

    int escolha1, escolha2;

    float valor1_c1 = 0, valor1_c2 = 0;
    float valor2_c1 = 0, valor2_c2 = 0;

    
    

    printf("===== SUPER TRUNFO - NIVEL MESTRE =====\n");
    printf("Escolha o PRIMEIRO atributo:\n");
    printf("1 - Populacao\n");
    printf("2 - Area\n");
    printf("3 - PIB\n");
    printf("4 - Pontos Turisticos\n");
    printf("5 - Densidade Demografica\n");
    printf("Opcao: ");
    scanf("%d", &escolha1);

    switch(escolha1) {

        case 1:
            valor1_c1 = populacao1;
            valor1_c2 = populacao2;
            break;

        case 2:
            valor1_c1 = area1;
            valor1_c2 = area2;
            break;

        case 3:
            valor1_c1 = pib1;
            valor1_c2 = pib2;
            break;

        case 4:
            valor1_c1 = pontos1;
            valor1_c2 = pontos2;
            break;

        case 5:
            valor1_c1 = densidade1;
            valor1_c2 = densidade2;
            break;

        default:
            printf("Opcao invalida!\n");
            return 0;
    }

   
    // SEGUNDO MENU (DINÂMICO)
    

    printf("\nEscolha o SEGUNDO atributo (diferente do primeiro):\n");

    if(escolha1 != 1) printf("1 - Populacao\n");
    if(escolha1 != 2) printf("2 - Area\n");
    if(escolha1 != 3) printf("3 - PIB\n");
    if(escolha1 != 4) printf("4 - Pontos Turisticos\n");
    if(escolha1 != 5) printf("5 - Densidade Demografica\n");

    printf("Opcao: ");
    scanf("%d", &escolha2);

    if(escolha2 == escolha1) {
        printf("Nao pode escolher o mesmo atributo duas vezes!\n");
        return 0;
    }

    switch(escolha2) {

        case 1:
            valor2_c1 = populacao1;
            valor2_c2 = populacao2;
            break;

        case 2:
            valor2_c1 = area1;
            valor2_c2 = area2;
            break;

        case 3:
            valor2_c1 = pib1;
            valor2_c2 = pib2;
            break;

        case 4:
            valor2_c1 = pontos1;
            valor2_c2 = pontos2;
            break;

        case 5:
            valor2_c1 = densidade1;
            valor2_c2 = densidade2;
            break;

        default:
            printf("Opcao invalida!\n");
            return 0;
    }

    
    // REGRA ESPECIAL DA DENSIDADE
    // (menor valor vence)
 

    if(escolha1 == 5) {
        valor1_c1 = -valor1_c1;
        valor1_c2 = -valor1_c2;
    }

    if(escolha2 == 5) {
        valor2_c1 = -valor2_c1;
        valor2_c2 = -valor2_c2;
    }

    
    // SOMA DOS ATRIBUTOS
   

    float soma1 = valor1_c1 + valor2_c1;
    float soma2 = valor1_c2 + valor2_c2;

    
    // EXIBIÇÃO DO RESULTADO
 

    printf("\n===== RESULTADO FINAL =====\n");
    printf("%s - Soma: %.2f\n", pais1, soma1);
    printf("%s - Soma: %.2f\n", pais2, soma2);

    // Operador ternário para decidir vencedor
    printf("\nVencedor: %s\n",
           (soma1 > soma2) ? pais1 :
           (soma2 > soma1) ? pais2 :
           "Empate!");

    return 0;
}
