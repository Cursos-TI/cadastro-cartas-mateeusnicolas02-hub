#include <stdio.h>

#define TAM 10        // Tamanho do tabuleiro (10x10)
#define NAVIO 3       // Valor que representa o navio
#define TAM_NAVIO 3   // Tamanho fixo dos navios

int main() {

    
    // 1. Criando e inicializando o tabuleiro
    
    int tabuleiro[TAM][TAM];

    // Inicializa todas as posições com 0 (água)
    for(int i = 0; i < TAM; i++) {
        for(int j = 0; j < TAM; j++) {
            tabuleiro[i][j] = 0;
        }
    }

    
    // 2. Posicionando os navios
    

    int valido;

    // -------- NAVIO 1 (Horizontal) --------
    int linha1 = 1;
    int coluna1 = 2;

    valido = 1;

    // Verifica se cabe no tabuleiro
    if(coluna1 + TAM_NAVIO > TAM) {
        valido = 0;
    }

    // Verifica sobreposição
    for(int i = 0; i < TAM_NAVIO && valido; i++) {
        if(tabuleiro[linha1][coluna1 + i] != 0) {
            valido = 0;
        }
    }

    // Posiciona o navio se for válido
    if(valido) {
        for(int i = 0; i < TAM_NAVIO; i++) {
            tabuleiro[linha1][coluna1 + i] = NAVIO;
        }
    }

    // -------- NAVIO 2 (Vertical) --------
    int linha2 = 5;
    int coluna2 = 0;

    valido = 1;

    if(linha2 + TAM_NAVIO > TAM) {
        valido = 0;
    }

    for(int i = 0; i < TAM_NAVIO && valido; i++) {
        if(tabuleiro[linha2 + i][coluna2] != 0) {
            valido = 0;
        }
    }

    if(valido) {
        for(int i = 0; i < TAM_NAVIO; i++) {
            tabuleiro[linha2 + i][coluna2] = NAVIO;
        }
    }

    // -------- NAVIO 3 (Diagonal principal ↘) --------
    int linha3 = 0;
    int coluna3 = 0;

    valido = 1;

    if(linha3 + TAM_NAVIO > TAM || coluna3 + TAM_NAVIO > TAM) {
        valido = 0;
    }

    for(int i = 0; i < TAM_NAVIO && valido; i++) {
        if(tabuleiro[linha3 + i][coluna3 + i] != 0) {
            valido = 0;
        }
    }

    if(valido) {
        for(int i = 0; i < TAM_NAVIO; i++) {
            tabuleiro[linha3 + i][coluna3 + i] = NAVIO;
        }
    }

    // -------- NAVIO 4 (Diagonal secundária ↙) --------
    int linha4 = 0;
    int coluna4 = 9;

    valido = 1;

    if(linha4 + TAM_NAVIO > TAM || coluna4 - (TAM_NAVIO - 1) < 0) {
        valido = 0;
    }

    for(int i = 0; i < TAM_NAVIO && valido; i++) {
        if(tabuleiro[linha4 + i][coluna4 - i] != 0) {
            valido = 0;
        }
    }

    if(valido) {
        for(int i = 0; i < TAM_NAVIO; i++) {
            tabuleiro[linha4 + i][coluna4 - i] = NAVIO;
        }
    }

  
    // 3. Exibindo o tabuleiro
   

    printf("\nTABULEIRO BATALHA NAVAL:\n\n");

    for(int i = 0; i < TAM; i++) {
        for(int j = 0; j < TAM; j++) {
            printf("%d ", tabuleiro[i][j]);
        }
        printf("\n");
    }

    return 0;
}
