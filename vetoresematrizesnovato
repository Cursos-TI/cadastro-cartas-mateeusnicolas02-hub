#include <stdio.h>

#define TAM 10        // Tamanho do tabuleiro (10x10)
#define TAM_NAVIO 3   // Tamanho fixo dos navios

int main() {

    // ==============================
    // 1. DECLARAÇÃO DO TABULEIRO
    // ==============================

    int tabuleiro[TAM][TAM];

    // Inicializa todas as posições com 0 (água)
    for(int linha = 0; linha < TAM; linha++) {
        for(int coluna = 0; coluna < TAM; coluna++) {
            tabuleiro[linha][coluna] = 0;
        }
    }

    // ==============================
    // 2. DECLARAÇÃO DOS NAVIOS
    // ==============================

    // Vetores que representam os navios (valor 3)
    int navioHorizontal[TAM_NAVIO] = {3, 3, 3};
    int navioVertical[TAM_NAVIO] = {3, 3, 3};

    // ==============================
    // 3. COORDENADAS INICIAIS
    // (Definidas diretamente no código)
    // ==============================

    int linhaH = 2;
    int colunaH = 3;

    int linhaV = 5;
    int colunaV = 7;

    // ==============================
    // 4. POSICIONAR NAVIO HORIZONTAL
    // ==============================

    // Verifica se cabe no tabuleiro
    if(colunaH + TAM_NAVIO <= TAM) {

        int podePosicionar = 1;

        // Verifica se já existe navio na posição
        for(int i = 0; i < TAM_NAVIO; i++) {
            if(tabuleiro[linhaH][colunaH + i] != 0) {
                podePosicionar = 0;
            }
        }

        // Se não houver sobreposição, posiciona o navio
        if(podePosicionar == 1) {
            for(int i = 0; i < TAM_NAVIO; i++) {
                tabuleiro[linhaH][colunaH + i] = navioHorizontal[i];
            }
        } else {
            printf("Erro: Navio horizontal sobreposto!\n");
        }

    } else {
        printf("Erro: Navio horizontal fora do tabuleiro!\n");
    }

    // ==============================
    // 5. POSICIONAR NAVIO VERTICAL
    // ==============================

    if(linhaV + TAM_NAVIO <= TAM) {

        int podePosicionar = 1;

        for(int i = 0; i < TAM_NAVIO; i++) {
            if(tabuleiro[linhaV + i][colunaV] != 0) {
                podePosicionar = 0;
            }
        }

        if(podePosicionar == 1) {
            for(int i = 0; i < TAM_NAVIO; i++) {
                tabuleiro[linhaV + i][colunaV] = navioVertical[i];
            }
        } else {
            printf("Erro: Navio vertical sobreposto!\n");
        }

    } else {
        printf("Erro: Navio vertical fora do tabuleiro!\n");
    }

    // ==============================
    // 6. EXIBIR TABULEIRO
    // ==============================

    printf("\n===== TABULEIRO =====\n\n");

    for(int linha = 0; linha < TAM; linha++) {
        for(int coluna = 0; coluna < TAM; coluna++) {
            printf("%d ", tabuleiro[linha][coluna]);
        }
        printf("\n");
    }

    return 0;
}
